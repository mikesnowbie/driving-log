rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Driving log entries. Open read/write since this is a private family
    // tool with no login system; access control relies on the Firestore
    // database ID and the app URL not being shared publicly.
    match /drives/{driveId} {
      allow read, write: if true;
    }

    // Single document tracking the currently in-progress drive, if any.
    match /meta/{docId} {
      allow read, write: if true;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
